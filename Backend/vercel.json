{
  "version": 2,
  "env": {
    "NODE_ENV": "production"
  },
  "builds": [
    { "src": "api/**/*.ts", "use": "@vercel/node" },
    { "src": "*.ts", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/[...path].ts" },
    { "src": "/health", "dest": "/health.ts" },
    { "src": "/", "dest": "/index.ts" }
  ]
}
